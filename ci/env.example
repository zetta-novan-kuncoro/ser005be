# ci/env.example
# ──────────────────────────────────────────────────────────────────────────────
# Jenkins Credentials Store — required for the sat-changelog Multibranch Pipeline
#
# Add each entry via:
#   Manage Jenkins → Credentials → (Global) → Add Credentials → Secret text
#
# The credential ID (left column) must match the string used in
# credentials('...') inside ci/Jenkinsfile exactly.
# ──────────────────────────────────────────────────────────────────────────────


# ── YouTrack Integration ──────────────────────────────────────────────────────

# ID: sat-changelog-youtrack-base-url
# e.g. https://youtrack.example.com
YOUTRACK_BASE_URL=

# ID: sat-changelog-youtrack-api-token
# Permanent token: YouTrack profile → Authentication → Permanent tokens
YOUTRACK_API_TOKEN=

# ID: sat-changelog-youtrack-project-id
# Short project name, e.g. SATCHG
YOUTRACK_PROJECT_ID=


# ── Backend Runtime ───────────────────────────────────────────────────────────

# ID: sat-changelog-mongo-uri
# Must be reachable from the Jenkins agent network.
# e.g. mongodb://user:pass@mongo-host:27017/sat_changelog_ci
MONGO_URI=

# ID: sat-changelog-jwt-secret
# Any strong random string; must match the value used when seeding the CI DB.
JWT_SECRET=

# ID: sat-changelog-encryption-key
# AES-GCM 256-bit key used for API key encryption at rest.
# Required for E2E tests that exercise the API key feature.
ENCRYPTION_KEY=


# ── E2E Admin Account ─────────────────────────────────────────────────────────
# Must match a real seeded user in the CI database.
# The E2E auth setup (e2e/fixtures/auth.setup.ts) logs in via the UI with these.

# ID: sat-changelog-e2e-admin-email
E2E_ADMIN_EMAIL=

# ID: sat-changelog-e2e-admin-password
E2E_ADMIN_PASSWORD=


# ── Notes ─────────────────────────────────────────────────────────────────────
# The following are set directly in the Jenkinsfile (not from credentials) and
# are listed here for completeness only — do NOT add them to the credentials
# store:
#
#   AUTOMATED_ISSUE_WRITE_BRANCHES=main,staging,dev_staging_feature
#     Overrides the tool default so dev_staging_feature is included.
#
#   AUTOMATED_ISSUE_CI_BRANCH  ← set from $BRANCH_NAME  (Jenkins built-in)
#   AUTOMATED_ISSUE_CI_COMMIT  ← set from $GIT_COMMIT    (Jenkins built-in)
#   AUTOMATED_ISSUE_CI_RUN_URL ← set from $BUILD_URL     (Jenkins built-in)
#
# Optional tuning (set as plain environment variables on the agent if needed):
#   BE_HEALTH_URL=http://localhost:4000/health   (default)
#   BE_HEALTH_TIMEOUT=60                         (seconds; raise for slow DBs)
#   AUTOMATED_ISSUE_DRY_RUN=true                 (skip YouTrack writes — useful
#                                                 when testing the pipeline)
