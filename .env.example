# MongoDB
MONGO_URI=mongodb://localhost:27017/sat_changelog

# Auth
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
ENCRYPTION_KEY=32_char_hex_key_here

# AWS S3
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret
AWS_S3_BUCKET=sat-changelog-assets

# JIRA
# Token type: Personal API token (not OAuth).
# Create at: https://id.atlassian.com/manage-profile/security/api-tokens
# Required account permission: "Create Issues" on the target project
#   (Project Settings → People → assign Developer role or a custom role with Create Issues).
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_USER_EMAIL=your@email.com        # Atlassian account email the token belongs to
JIRA_API_TOKEN=<JIRA API token>
JIRA_PROJECT_KEY=<e.g. ADMTCRA26Q1>  # Short project key shown in JIRA project settings
# JIRA_WEBHOOK_SECRET is used to verify the X-Hub-Signature HMAC-SHA256 on incoming webhook events.
# Generate a strong random secret and configure the same value in your JIRA webhook settings.
JIRA_WEBHOOK_SECRET=<random secret shared with JIRA webhook configuration>

# YouTrack
# Token type: Personal permanent token (Hub → Authentication → Permanent Tokens).
# Required permission: "Create Issue" on the target project.
# YOUTRACK_PROJECT_ID must be the internal UUID, not the short name (e.g. not "SAT").
# Retrieve it via: GET /api/admin/projects?fields=id,name,shortName
YOUTRACK_BASE_URL=https://your-org.youtrack.cloud  # no trailing slash
YOUTRACK_API_TOKEN=<YouTrack token>
YOUTRACK_PROJECT_ID=<internal project ID in 0-N format — get via GET /api/admin/projects?fields=id,name,shortName>

# App
NODE_ENV=development
PORT=4000
APP_BASE_URL=http://localhost:4000
